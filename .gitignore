# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
*.egg-info/

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store

# Alma (AI assistant)
.alma-snapshots/
.alma/

# Environment
.env

# OPC runtime files
opc/runtime/*
opc/logs/sessions/*
opc/logs/prompts/*
opc/logs/raw_outputs/*
opc/logs/command_runs/*
opc/logs/events.jsonl
opc/logs/metrics.json
opc/logs/dashboard.html

# 队列目录
opc/tasks/done/      # 已完成任务
opc/tasks/inbox/*.md  # inbox 中的任务文件由用户管理，不进 git

# Session 独立目录（每个任务的中间状态）
opc/tasks/20*-*/

# 保留目录结构
!opc/runtime/.gitkeep
!opc/logs/sessions/.gitkeep
!opc/logs/prompts/.gitkeep
!opc/logs/raw_outputs/.gitkeep
!opc/logs/command_runs/.gitkeep

# OPC generated files
server.py
server.py.bak
